generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Roles del sistema (Evaluación 3)
enum Role {
  ADMIN
  VENDEDOR
}

// 2. Modelo de Usuario (Actualizado con relación para la Evaluación 3)
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String
  role          Role           @default(VENDEDOR)
  sales         Sale[]         // Usuario se relaciona con ventas
  refreshTokens RefreshToken[] // <-- NUEVO: Relación requerida para control de sesiones activas
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt     // <-- Corregido el detalle del caracter '|'
}

// 3. Modelo de Producto (Inventario Global, visible para todos los usuarios)
model Product {
  id_producto       String       @id @default(cuid())
  nombre_producto   String
  descripcion       String?
  stock             Int          @default(0)
  precio            Int
  fecha_vencimiento DateTime?
  saleDetails       SaleDetail[] // Relación: Un producto puede estar en muchos detalles de boletas
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

// 4. CABECERA DE LA VENTA (La Boleta)
model Sale {
  id_venta    String       @id @default(cuid())
  total       Int          // El total de la boleta (ej: 23950)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // El vendedor que realizó la venta
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Las líneas de detalle que componen esta boleta
  details     SaleDetail[]

  @@index([userId])
}

// 5. DETALLE DE LA VENTA (Las líneas de la boleta)
model SaleDetail {
  id_detalle      String   @id @default(cuid())
  cantidad        Int      @default(1) // Ej: 3 galletas
  precio_unitario Int      // Guardamos el precio del momento por si llega a cambiar en el inventario

  // Conexión con la boleta padre
  id_venta        String
  sale            Sale     @relation(fields: [id_venta], references: [id_venta], onDelete: Cascade)

  // Conexión con el producto vendido
  id_producto     String
  product         Product  @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade)

  @@index([id_venta])
  @@index([id_producto])
}

// 6. CONTROL DE TOKENS Y ROTACIÓN (Evaluación 3)
model RefreshToken {
  id                String   @id @default(cuid()) // Mantenemos consistencia usando cuid()
  jti               String   @unique              // Identificador único de este token específico
  tokenHash         String                        // Hash SHA-256 del refresh token (nunca plano)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade) // Borrado en cascada
  isRevoked         Boolean  @default(false)
  replacedByTokenId String?                       // Rastro del nuevo token si fue rotado
  createdAt         DateTime @default(now())
  expiresAt         DateTime

  @@index([userId])
}