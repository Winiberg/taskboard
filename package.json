{
  "name": "sistema_inventario",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev:api": "pnpm -C apps/api start:dev",
    "dev:web": "pnpm -C apps/web dev",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "build": "pnpm -C apps/api build && pnpm -C apps/web build",
    "lint": "pnpm -C apps/api lint && pnpm -C apps/web lint",
    "format": "prettier --w ."
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "prettier": "^3.3.0",
    "prisma": "5.15.0"
  },
  "dependencies": {
    "@prisma/client": "5.15.0"
  }
}
